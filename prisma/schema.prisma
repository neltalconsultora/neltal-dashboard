// NELTAL - Schema PostgreSQL (Supabase) - Completo

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Cliente {
  id              String   @id @default(cuid())
  nombre          String
  nombreNegocio   String
  giro            String?
  giroOtro        String?
  telefono        String?
  email           String?
  ubicacion       String?
  tiempoOperacion Int      @default(0)
  empleados       Int      @default(0)
  tieneLocal      Boolean  @default(false)
  status          String   @default("prospecto")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  diagnosticos Diagnostico[]
}

model Diagnostico {
  id                      String   @id @default(cuid())
  clienteId               String
  cliente                 Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  
  // Respuestas
  respuestas              String?
  
  // Métricas de Ventas
  ventasMesPromedio       Float?   @default(0)
  ventasMesBuenas         Float?   @default(0)
  ventasMesMalas          Float?   @default(0)
  variabilidadIngresos    Float?   @default(0)
  variabilidadNivel       String?
  
  // Ciclo de Conversión de Efectivo
  cccDias                 Float?   @default(0)
  cccNivel                String?
  
  // Concentración de Clientes
  concentracionPrincipal  Float?   @default(0)
  concentracionTop3       Float?   @default(0)
  concentracionNivel      String?
  
  // Índice de Dependencia del Dueño
  idd                     Float?   @default(0)
  iddNivel                String?
  
  // Gap de Formalización
  gfActual                Float?   @default(0)
  gfGap                   Float?   @default(0)
  gfNivel                 String?
  
  // Estructura de Costos
  gastosFijos             Float?   @default(0)
  gastosVariables         Float?   @default(0)
  gastosTotales           Float?   @default(0)
  puntoEquilibrio         Float?   @default(0)
  utilidadEstimada        Float?   @default(0)
  margenUtilidad          String?
  
  // Antigüedad
  antiguedad              Float?   @default(0)
  antiguedadNivel         String?
  
  // Análisis (JSON)
  alertas                 String?
  fortalezas              String?
  recomendaciones         String?
  oportunidades           String?
  
  // Estado
  estado                  String   @default("pendiente")
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
